{
  "manifest_version": 3,
  "name": "Vịt Quay Nhiều Vị",
  "version": "1.1",
  "permissions": [
    "cookies",
    "scripting",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "*://*.studocu.com/*",
    "*://*.studocu.vn/*"
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bánh Mì Cầm Phả",
    "default_icon": "logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer_styles.css"
      ],
      "matches": [
        "*://*.studocu.com/*",
        "*://*.studocu.vn/*"
      ]
    }
  ]
}
